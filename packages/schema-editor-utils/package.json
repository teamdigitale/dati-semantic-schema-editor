{
  "name": "@teamdigitale/schema-editor-utils",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamdigitale/dati-semantic-schema-editor.git",
    "directory": "packages/schema-editor-utils"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "immutable": "^5.1.4",
    "js-yaml": "^4.1.1",
    "jsonld": "^9.0.0",
    "lz-string": "^1.5.0",
    "swagger-client": "^3.36.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsonld": "^1.5.15",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  }
}
