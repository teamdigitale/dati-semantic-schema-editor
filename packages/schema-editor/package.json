    "test": "vitest run"
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@teamdigitale/schema-editor-utils": "workspace:*",
    "bootstrap": "^5.3.8",
    "bootstrap-italia": "2.10.0",
    "cytoscape": "^3.33.1",
    "cytoscape-fcose": "^2.2.0",
    "design-react-kit": "5.2.0",
    "immutable": "^5.1.4",
    "js-yaml": "^4.1.1",
    "jsonld": "^9.0.0",
    "lz-string": "^1.5.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dropzone": "^15.0.0",
    "styled-components": "^6.3.11",
    "use-debounce": "^10.1.0"
  },
  "peerDependencies": {
